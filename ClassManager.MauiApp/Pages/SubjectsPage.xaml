<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ClassManager.MauiApp.Pages"
             xmlns:models="clr-namespace:ClassManager.UIModels;assembly=ClassManager.UIModels"
             x:Class="ClassManager.MauiApp.Pages.SubjectsPage"
             x:DataType="pages:SubjectsPage"
             Title="Subjects">

    <CollectionView
        x:Name="SubjectsCollectionView"
        ItemsSource="{Binding Subjects}"
        Margin="10"
        SelectionMode="Single"
        SelectionChanged="SubjectSelected">


        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:SubjectUIModel">
                <Border Stroke="Magenta" Padding="10" Margin="0,10">
                    <VerticalStackLayout>
                        <Label Text="{Binding Name}" />
                        <Label Text="{Binding Credits}" />
                        <Label Text="{Binding Sphere}" />
                        <Label Text="{Binding LessonsDesc, StringFormat='Lessons: {0}'}" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>
