<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ClassManager.UIModels;assembly=ClassManager.UIModels"
             x:Class="ClassManager.MauiApp.Pages.SubjectDetailsPage"
             x:DataType="models:SubjectUIModel"
             Title="Subject Details">

    <VerticalStackLayout Padding="20" Spacing="12">

        <Label Text="{Binding Name}" FontSize="24" HorizontalOptions="Center" />
        <Label Text="{Binding Sphere}" HorizontalOptions="Center" />
        <Label Text="{Binding Credits, StringFormat='Credits: {0}'}" HorizontalOptions="Center" />
        <Label Text="{Binding DurationAll, StringFormat='Total duration: {0}'}" HorizontalOptions="Center" />

        <CollectionView
            ItemsSource="{Binding Lessons}"
            Margin="0,10,0,0"
            SelectionMode="Single"
            SelectionChanged="LessonsCollectionView_SelectionChanged">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LessonUIModel">
                    <Border Stroke="Magenta" Padding="10" Margin="0,6">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Topic}" FontSize="18" />
                            <Label Text="{Binding Type}" />
                            <Label Text="{Binding Date, StringFormat='Date: {0:dd.MM.yyyy}'}" />
                            <Label Text="{Binding LessonDuration, StringFormat='Duration: {0}'}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
