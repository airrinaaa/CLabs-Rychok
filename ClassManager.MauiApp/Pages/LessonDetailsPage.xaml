<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClassManager.MauiApp.Pages.LessonDetailsPage"
             Title="Lesson Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label x:Name="LessonTopicLabel" FontSize="24" HorizontalOptions="Center" />
            <Label x:Name="LessonDateLabel" HorizontalOptions="Center" />
            <Label x:Name="LessonTypeLabel" HorizontalOptions="Center" />
            <Label x:Name="LessonStartTimeLabel" HorizontalOptions="Center" />
            <Label x:Name="LessonEndTimeLabel" HorizontalOptions="Center" />
            <Label x:Name="LessonDurationLabel" HorizontalOptions="Center" />
            <Label x:Name="LessonInfoLabel"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
